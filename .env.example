# Surgical RAG-VQA — Environment Variables
# Copy this to .env and fill in your values

# Mode selection
# openai   : use OpenAI VLM
# local_hf : use a local Hugging Face VLM
# mock_vlm : do not call a VLM; useful for retrieval/pipeline smoke tests
VLM_PROVIDER=mock_vlm

# OpenAI mode
OPENAI_API_KEY=sk-your-key-here
OPENAI_VLM_MODEL=gpt-4o

# Hugging Face mode
HF_TOKEN=hf_your_read_token_here
HF_CACHE_DIR=
HF_LOCAL_FILES_ONLY=0
LOCAL_VLM_MODEL=llava-hf/llava-1.5-7b-hf
LOCAL_VLM_MAX_NEW_TOKENS=256

# Retrieval
RETRIEVAL_MODE=hybrid
DENSE_MODEL_NAME=BAAI/bge-large-en-v1.5
USE_RERANKER=1
RERANKER_MODEL_NAME=BAAI/bge-reranker-large
RERANK_TOP_N=20